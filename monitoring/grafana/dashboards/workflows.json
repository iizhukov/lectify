      "targets": [
        {
          "expr": "(rate(lectify_workflows_failed_total[5m]) / rate(lectify_workflows_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "title": "Failure Rate %",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
