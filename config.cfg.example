[OpenAI]
API_KEY = your_api_key_here
URL = provider_url
REASONING = True
STREAM = False

[Database]
DRIVER = postgresql
USERNAME = lectify
PASSWORD = lectify_password
HOST = localhost
PORT = 5432
DATABASE = lectify
# Опционально:
CONNECTION_URL = postgresql://lectify:lectify_password@localhost:5432/lectify

[Database.Test]
# Тестовая БД (используется при запуске тестов)
DATABASE = lectify_test
CONNECTION_URL = postgresql://lectify:lectify_password@localhost:5432/lectify_test

[MinIO]
# S3-совместимое хранилище для артефактов
ENDPOINT = localhost:9000
ACCESS_KEY = minioadmin
SECRET_KEY = minioadmin
SECURE = False
ARTIFACTS_BUCKET = artifacts
LOGS_BUCKET = logs

[Monitoring]
# Prometheus метрики
PROMETHEUS_ENABLED = True
PROMETHEUS_PORT = 8000

# Grafana для визуализации
GRAFANA_ENABLED = True
GRAFANA_PORT = 3000
GRAFANA_ADMIN_USER = admin
GRAFANA_ADMIN_PASSWORD = admin

# Loki для логирования
LOKI_ENABLED = True
LOKI_URL = http://localhost:3100
LOKI_TENANT_ID = lectify

# Alertmanager для оповещений
ALERTMANAGER_ENABLED = True
ALERTMANAGER_URL = http://localhost:9093

# Telegram для уведомлений об алертах (опционально)
TELEGRAM_ENABLED = False
TELEGRAM_BOT_TOKEN = your_bot_token_here
TELEGRAM_CHAT_ID = your_chat_id_here

[Logging]
# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL = INFO
LOG_FILE = logs/lectify.log

# Отправка логов в MinIO
UPLOAD_LOGS_TO_MINIO = True

# Ротация лог-файлов
LOG_FILE_MAX_BYTES = 10485760  # 10MB
LOG_FILE_BACKUP_COUNT = 5

[Orchestrator]
# Оркестратор выполняет воркфлоу в Docker-контейнерах
ENABLED = True
# Максимальное число одновременно выполняемых воркфлоу
MAX_CONCURRENT_WORKFLOWS = 100
# Максимальное число одновременно выполняемых нод
MAX_CONCURRENT_NODES = 5
# Интервал опроса БД на новые задачи (секунды)
POLL_INTERVAL_SECONDS = 5
# Таймаут выполнения одной ноды (секунды)
NODE_TIMEOUT_SECONDS = 600
# Автоматически перезапускать упавшие ноды
AUTO_RETRY_FAILED_NODES = True
# Максимум перезапусков для одной ноды
MAX_NODE_RETRIES = 2
