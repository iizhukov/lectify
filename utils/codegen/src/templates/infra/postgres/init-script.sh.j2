#!/bin/bash
# ---------------------------------------------------------------------------
# Auto-generated by codegen — do not edit manually.
# To regenerate: codegen infra
# ---------------------------------------------------------------------------
# PostgreSQL initialization script
# Creates users and databases for all services
# ============================================================

set -e

echo "🐘 Initializing PostgreSQL..."

# ============================================
# Wait for PostgreSQL to be ready
# ============================================
echo "Waiting for PostgreSQL to be ready..."
until pg_isready -U {{ settings.POSTGRES_USER }} >/dev/null 2>&1; do
    echo "Waiting for PostgreSQL to be ready..."
    sleep 1
done
echo "✅ PostgreSQL is ready!"

# ============================================
# Create users and databases
# ============================================
echo "👤 Creating users and databases..."

{% for service_name in services %}
# ============================================
# {{ service_name }}
# ============================================

# Get password from context
PASSWORD="{{ context.services[service_name].postgres_password }}"
DATABASE="{{ service_name | replace('-', '_') }}"

# Create user if not exists (DO block is fine for CREATE USER)
echo "Creating user: {{ service_name }}"
psql -U {{ settings.POSTGRES_USER }} -c "DO \$\$ BEGIN CREATE USER {{ service_name }} WITH PASSWORD '$PASSWORD'; EXCEPTION WHEN duplicate_object THEN RAISE NOTICE 'User {{ service_name }} already exists'; END \$\$;"

# Create database if not exists (outside transaction block)
echo "Creating database: $DATABASE"
DB_EXISTS=$(psql -U {{ settings.POSTGRES_USER }} -tAc "SELECT 1 FROM pg_database WHERE datname='$DATABASE'")
if [ "$DB_EXISTS" = "1" ]; then
    echo "Database $DATABASE already exists, skipping creation"
else
    psql -U {{ settings.POSTGRES_USER }} -c "CREATE DATABASE $DATABASE OWNER {{ service_name }};"
fi

# Grant privileges (safe to repeat)
echo "Granting privileges..."
psql -U {{ settings.POSTGRES_USER }} -c "GRANT ALL PRIVILEGES ON DATABASE $DATABASE TO {{ service_name }};"

{% endfor %}

echo ""
echo "✅ All PostgreSQL users and databases initialized!"
echo ""
echo "📊 Summary:"
{% for service_name in services %}
echo "  {{ service_name }}:"
echo "    - Database: {{ service_name | replace('-', '_') }}"
echo "    - User: {{ service_name }}"
{% endfor %}