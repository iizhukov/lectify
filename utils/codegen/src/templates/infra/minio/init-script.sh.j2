#!/bin/bash
# ---------------------------------------------------------------------------
# Auto-generated by codegen — do not edit manually.
# To regenerate: codegen infra
# ---------------------------------------------------------------------------
# MinIO initialization script
# Creates buckets and users for all services
# ============================================================

set -e

echo "🔐 Initializing MinIO..."

# ============================================
# Wait for MinIO to be ready
# ============================================
echo "Waiting for MinIO to be ready..."
until mc alias set myminio http://minio:{{ settings.MINIO_API_PORT }} {{ settings.MINIO_ROOT_USER }} {{ settings.MINIO_ROOT_PASSWORD }} >/dev/null 2>&1; do
    echo "Waiting for MinIO to be ready..."
    sleep 1
done
echo "✅ MinIO is ready!"

# ============================================
# Create buckets
# ============================================
echo "📦 Creating buckets..."

{% for bucket in buckets %}
mc mb myminio/{{ bucket }} --ignore-existing
{% endfor %}

# ============================================
# Create users and attach readwrite policy
# ============================================
echo "👤 Creating users and setting policies..."

{% for service_name, buckets in service_to_buckets.items() %}
# ============================================
# {{ service_name }}
# ============================================

# Get password from context
PASSWORD="{{ context.services[service_name].minio_password }}"

# Create user if not exists
if ! mc admin user info myminio {{ service_name }} >/dev/null 2>&1; then
    echo "Creating user: {{ service_name }}"
    mc admin user add myminio {{ service_name }} "$PASSWORD"
else
    echo "User {{ service_name }} already exists, skipping"
fi

# Create custom policy (restricts user to specific buckets)
cat > /tmp/policy-{{ service_name }}.json <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
{% for bucket in buckets %}
        "arn:aws:s3:::{{ bucket }}",
        "arn:aws:s3:::{{ bucket }}/*"{% if not loop.last %},{% endif %}
{% endfor %}
      ]
    }
  ]
}
EOF

mc admin policy create myminio {{ service_name }}-policy /tmp/policy-{{ service_name }}.json
mc admin policy attach myminio {{ service_name }}-policy --user {{ service_name }}

{% endfor %}

echo ""
echo "✅ All MinIO buckets and users initialized!"
echo ""
echo "📊 Summary:"
{% for service_name, buckets in service_to_buckets.items() %}
echo "  {{ service_name }}:"
{% for bucket in buckets %}
echo "    - {{ bucket }}"
{% endfor %}
{% endfor %}
