# ---------------------------------------------------------------------------
# Auto-generated by codegen — do not edit manually.
# To regenerate: codegen generate
# ---------------------------------------------------------------------------

.PHONY: help run run-vault run-direct clean health

SERVICE_NAME := {{ service.name }}
SERVICE_ID := {{ service.id }}
GRPC_PORT := {{ service.grpc.port }}
VAULT_ENABLED := {{ service.vault.enabled }}
{% if service.vault.enabled %}
VAULT_CONFIG := generated/vault/agent-{{ service.name }}.local.hcl
{% endif %}

# Colors for output
GREEN := \033[0;32m
RED := \033[0;31m
YELLOW := \033[0;33m
NC := \033[0m # No Color

help:
	@echo "$(GREEN)Available commands:$(NC)"
	@echo "  $(YELLOW)make run$(NC)          - Run the service (auto-detect Vault)"
	@echo "  $(YELLOW)make run-direct$(NC)   - Run directly without Vault"
	@echo "  $(YELLOW)make clean$(NC)        - Clean generated files"
	@echo "  $(YELLOW)make health$(NC)       - Check service health"
{% if service.vault.enabled %}
	@echo "  $(YELLOW)make run-vault$(NC)    - Run with Vault Agent"
	@echo "  $(YELLOW)make vault-init$(NC)   - Initialize Vault for this service"
{% endif %}
	@echo ""
	@echo "Configuration:"
	@echo "  Service: $(GREEN)$(SERVICE_NAME)$(NC)"
	@echo "  gRPC port: $(GREEN)$(GRPC_PORT)$(NC)"
{% if service.vault.enabled %}
	@echo "  Vault enabled: $(GREEN)$(VAULT_ENABLED)$(NC)"
{% endif %}

{% if service.vault.enabled %}

check-vault:
	@command -v vault >/dev/null 2>&1 || { echo "$(RED)Vault not found. Install with: brew install hashicorp/tap/vault$(NC)"; exit 1; }

check-vault-config:
	@if [ -f $(VAULT_CONFIG) ]; then \
		echo "$(GREEN)Vault config found$(NC)"; \
	else \
		echo "$(YELLOW)No Vault config found, please run: codegen generate$(NC)"; \
		exit 1; \
	fi

check-secrets:
	@if [ -f vault/$(SERVICE_ID)-role-id.txt ] && [ -f vault/$(SERVICE_ID)-secret-id.txt ]; then \
		echo "$(GREEN)Vault secrets found$(NC)"; \
	else \
		echo "$(YELLOW)Vault secrets not found, running vault-init...$(NC)"; \
		$(MAKE) vault-init; \
	fi

vault-init: check-vault
	@echo "$(GREEN)Initializing Vault for $(SERVICE_NAME)...$(NC)"
	@mkdir -p vault
	@if [ -f generated/scripts/init-vault.sh ]; then \
		chmod +x generated/scripts/init-vault.sh; \
		./generated/scripts/init-vault.sh; \
	else \
		echo "$(RED)Init script not found: generated/scripts/init-vault.sh$(NC)"; \
		echo "$(YELLOW)Please run: codegen generate$(NC)"; \
		exit 1; \
	fi

run-vault: check-vault check-vault-config check-secrets
	@echo "$(GREEN)Running $(SERVICE_NAME) with Vault Agent...$(NC)"
	VAULT_ADDR=$${VAULT_ADDR:-http://localhost:8200} vault agent -config=$(VAULT_CONFIG)

{% endif %}

run:
	@echo "$(GREEN)Running $(SERVICE_NAME)...$(NC)"
{% if service.vault.enabled %}
	@if command -v vault >/dev/null 2>&1 && [ -f $(VAULT_CONFIG) ]; then \
		echo "$(GREEN)Starting with Vault Agent...$(NC)"; \
		$(MAKE) check-secrets; \
		VAULT_ADDR=$${VAULT_ADDR:-http://localhost:8200} vault agent -config=$(VAULT_CONFIG); \
	else \
		echo "$(YELLOW)Running directly...$(NC)"; \
		python generated/main.py; \
	fi
{% else %}
	@echo "$(YELLOW)Running directly...$(NC)"
	python generated/main.py
{% endif %}

run-direct:
	@echo "$(GREEN)Running $(SERVICE_NAME) directly...$(NC)"
	python generated/main.py

health:
	@echo "$(GREEN)Checking service health...$(NC)"
	@OUTPUT=$$(grpcurl -plaintext -max-time 3 localhost:$(GRPC_PORT) grpc.health.v1.Health/Check 2>&1); \
	if [ $$? -eq 0 ]; then \
		echo "$(GREEN)✅ Service is healthy!$(NC)"; \
	else \
		echo "$(RED)❌ Health check failed: $${OUTPUT}$(NC)"; \
	fi

clean:
	@echo "$(GREEN)Cleaning generated files...$(NC)"
	rm -rf generated/
	rm -rf __pycache__/
	rm -rf .pytest_cache/
	rm -rf *.egg-info/
	rm -rf vault/
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete
