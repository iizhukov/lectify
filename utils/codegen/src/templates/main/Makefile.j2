.PHONY: help run run-vault run-direct docker-up docker-down docker-build test clean

SERVICE_NAME := {{ service.name }}
VAULT_ENABLED := {{ service.vault.enabled }}
HAS_GRPC := {{ service.grpc.enabled }}
GRPC_PORT := {{ service.grpc.port }}

# Colors for output
GREEN := \033[0;32m
RED := \033[0;31m
YELLOW := \033[0;33m
NC := \033[0m # No Color

help:
	@echo "$(GREEN)Available commands:$(NC)"
	@echo "  $(YELLOW)make run$(NC)          - Run the service (auto-detect Vault)"
	@echo "  $(YELLOW)make run-direct$(NC)   - Run directly without Vault"
	@echo "  $(YELLOW)make run-vault$(NC)    - Run with Vault Agent (if enabled)"
	@echo "  $(YELLOW)make clean$(NC)        - Clean generated files"
	@echo ""
	@echo "Configuration:"
	@echo "  Service: $(GREEN)$(SERVICE_NAME)$(NC)"
	@echo "  Vault enabled: $(GREEN)$(VAULT_ENABLED)$(NC)"
	@echo "  gRPC enabled: $(GREEN)$(HAS_GRPC)$(NC)"

check-vault:
	@command -v vault >/dev/null 2>&1 || { echo "$(RED)Vault not found. Install with: brew install hashicorp/tap/vault$(NC)"; exit 1; }

check-vault-config:
	@if [ -f vault/agent-$(SERVICE_NAME).hcl ]; then \
		echo "$(GREEN)Vault config found$(NC)"; \
	else \
		echo "$(YELLOW)No Vault config found, running in direct mode$(NC)"; \
		exit 1; \
	fi

run:
	@echo "$(GREEN)Running $(SERVICE_NAME)...$(NC)"
	@if command -v vault >/dev/null 2>&1 && [ -f vault/agent-$(SERVICE_NAME).hcl ]; then \
		echo "$(GREEN)Starting with Vault Agent...$(NC)"; \
		VAULT_ADDR=$${VAULT_ADDR:-http://vault:8200} vault agent -config=vault/agent-$(SERVICE_NAME).hcl; \
	else \
		echo "$(YELLOW)Running directly...$(NC)"; \
		python generated/main.py; \
	fi

run-direct:
	@echo "$(GREEN)Running $(SERVICE_NAME) directly...$(NC)"
	python generated/main.py

run-vault: check-vault check-vault-config
	@echo "$(GREEN)Running $(SERVICE_NAME) with Vault Agent...$(NC)"
	VAULT_ADDR=$${VAULT_ADDR:-http://vault:8200} vault agent -config=vault/agent-$(SERVICE_NAME).hcl

# Очистка
clean:
	@echo "$(GREEN)Cleaning generated files...$(NC)"
	rm -rf generated/
	rm -rf __pycache__/
	rm -rf .pytest_cache/
	rm -rf *.egg-info/
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete

# Проверка health
health:
	@echo "$(GREEN)Checking service health...$(NC)"
	@OUTPUT=$$(grpcurl -plaintext -max-time 3 localhost:$(GRPC_PORT) grpc.health.v1.Health/Check 2>&1); \
	if [ $$? -eq 0 ]; then \
		echo "$(GREEN)✅ Service is healthy!$(NC)"; \
	else \
		echo "$(RED)❌ Health check failed: $${OUTPUT}$(NC)"; \
	fi
