class DatabaseSettings(BaseSettings):
    model_config = SettingsConfigDict(env_prefix="{{ service.name | upper | replace("-", "_") }}_DB_", extra="ignore")

    url: str = Field(
        default="postgresql+asyncpg://{{ service.name }}:{{ context.postgres_password }}@localhost:{{ settings.POSTGRES_PORT }}/{{ service.name | replace("-", "_")}}",
        description="Async database DSN",
    )
    pool_size: int = Field(default={{service.postgres.pool_size}}, ge=1)
    pool_max_overflow: int = Field(default={{service.postgres.pool_max_overflow}}, ge=0)
    pool_mode: str = Field(default="{{service.postgres.pool_mode}}")


