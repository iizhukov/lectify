#!/bin/bash
# ---------------------------------------------------------------------------
# Auto-generated by codegen — do not edit manually.
# To regenerate: codegen generate
# ---------------------------------------------------------------------------

set -e

SERVICE_NAME="{{ service.name }}"
VAULT_ADDR="http://{{ vault_addr }}:{{ settings.VAULT_PORT }}"
VAULT_TOKEN="{{ settings.VAULT_DEV_ROOT_TOKEN_ID }}"

echo "🔐 Initializing Vault for ${SERVICE_NAME}..."

# Проверка доступности Vault
if ! VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault status >/dev/null 2>&1; then
    echo "❌ Vault is not accessible at $VAULT_ADDR"
    echo "   Run: docker run -d --name vault-dev -p 8200:8200 -e VAULT_DEV_ROOT_TOKEN_ID=root hashicorp/vault:latest"
    exit 1
fi
echo "✅ Vault is running"

# Подготовка директорий
mkdir -p vault

# Настройка AppRole
if VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault auth enable approle 2>/dev/null; then
    echo "✅ AppRole enabled"
else
    echo "ℹ️ AppRole already enabled"
fi

# Создание политики доступа
if VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault policy read "${SERVICE_NAME}-policy" >/dev/null 2>&1; then
    echo "ℹ️ Policy '${SERVICE_NAME}-policy' already exists"
else
    VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault policy write "${SERVICE_NAME}-policy" - <<EOF
path "secret/data/${SERVICE_NAME}/*" {
  capabilities = ["read", "create", "update", "list"]
}
EOF
    echo "✅ Policy '${SERVICE_NAME}-policy' created"
fi

# Создание AppRole роли
if VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault read auth/approle/role/"${SERVICE_NAME}-role" >/dev/null 2>&1; then
    echo "ℹ️ AppRole '${SERVICE_NAME}-role' already exists"
else
    VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault write auth/approle/role/"${SERVICE_NAME}-role" \
        secret_id_ttl=24h \
        token_ttl=1h \
        token_max_ttl=4h \
        policies="${SERVICE_NAME}-policy"
    echo "✅ AppRole '${SERVICE_NAME}-role' created"
fi

# Создание секретов
SECRET_PATH="secret/${SERVICE_NAME}/settings"

if VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault kv get "$SECRET_PATH" >/dev/null 2>&1; then
    echo "ℹ️ Secrets already exist at ${SECRET_PATH}"
else
    echo "📝 Creating secrets at ${SECRET_PATH}..."
    
    SECRETS=""
{% for var_name, var_value in vault_vars.items() %}
    SECRETS="$SECRETS {{ var_name }}={{ var_value }}"
{% endfor %}
    
    VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault kv put "$SECRET_PATH" $SECRETS
    echo "✅ Secrets created"
fi

# Сохранение Role ID
ROLE_ID_FILE="vault/${SERVICE_NAME}-role-id.txt"

if [ -f "$ROLE_ID_FILE" ]; then
    echo "ℹ️ Role ID file already exists: $ROLE_ID_FILE"
else
    VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault read -field=role_id auth/approle/role/"${SERVICE_NAME}-role"/role-id > "$ROLE_ID_FILE"
    echo "✅ Role ID saved to $ROLE_ID_FILE"
fi


# Сохранение Secret ID
SECRET_ID_FILE="vault/${SERVICE_NAME}-secret-id.txt"

if [ -f "$SECRET_ID_FILE" ]; then
    echo "ℹ️ Secret ID file already exists: $SECRET_ID_FILE"
else
    VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" vault write -f -field=secret_id auth/approle/role/"${SERVICE_NAME}-role"/secret-id > "$SECRET_ID_FILE"
    echo "✅ Secret ID saved to $SECRET_ID_FILE"
fi


echo ""
echo "✅ Vault initialized successfully for ${SERVICE_NAME}"
echo ""
echo "Files:"
echo "   - $ROLE_ID_FILE"
echo "   - $SECRET_ID_FILE"
