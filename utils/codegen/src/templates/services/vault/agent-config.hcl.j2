# Auto-generated by codegen - do not edit manually
# Vault Agent Configuration for {{ service.name }}

vault {
  address = "http://{{ vault.addr }}:{{ vault.port }}"
}

# Запуск Python-приложения
exec {
  command = ["python", "generated/main.py"]
  restart_on_secret_changes = "always"
}

# Auto-Auth через AppRole
auto_auth {
  method "approle" {
    config = {
      role_id_file_path   = "{{ svc_dir }}/vault/{{ service.name }}-role-id.txt"
      secret_id_file_path = "{{ svc_dir }}/vault/{{ service.name }}-secret-id.txt"
      remove_secret_id_file_after_reading = false
    }
  }
}

# Настройки шаблонов
template_config {
  static_secret_render_interval = "30s"
  exit_on_retry_failure = true
}

# ===== Переменные из Vault (можно переопределять) =====
{% for var_name, var_value in vault_vars.items() %}
env_template "{{ var_name }}" {
  contents = "{{ "{{" }} with secret \"secret/{{ service.name }}/settings\" {{ "}}" }}{{ "{{" }} .Data.data.{{ var_name }} {{ "}}" }}{{ "{{" }} end {{ "}}" }}"
  error_on_missing_key = false
}
{% endfor %}

# ===== Статические переменные (не из Vault) =====
{% for var_name, var_value in static_vars.items() %}
env "{{ var_name }}" {
    value = "{{ var_value }}"
}
{% endfor %}
